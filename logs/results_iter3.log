**Code Explanation:**

This script generates Zel'dovich Approximation (ZA) initial conditions for a cosmological N-body simulation matching the Quijote fiducial cosmology. 

Key steps:
1. Uses CAMB to compute linear matter power spectrum P(k) at z_init=127 and z=0, plus HaloFit nonlinear P(k) at z=0, 0.5, 1, 2
2. Generates a 512³ Gaussian random field in Fourier space with amplitude N³/sqrt(2V) * sqrt(P_lin(k, z_init)), fixed seed=0
3. Computes ZA displacement field via Fourier-space gradient of the potential (Psi = -i*k/k² * delta)
4. Displaces particles from a regular Lagrangian grid
5. Assigns velocities using ZA: v = a*H*f*Psi with f_growth=1.0 at z=127 (matter dominated)
6. Attempts to download Quijote reference P(k) from GitHub; falls back to CAMB HaloFit
7. Saves all arrays to disk

Units: positions in Mpc/h, velocities in km/s (peculiar velocities = a*H*f*Psi where H=H(z_init) in km/s/(Mpc/h)), k in h/Mpc, P(k) in (Mpc/h)³.

The amplitude normalization N³/sqrt(2V)*sqrt(P_lin) ensures the correct variance of the density field on the discrete grid. The factor sqrt(2) accounts for the real/imaginary parts each having variance P(k)/2.

**Python Code:**

```python
import numpy as np
import camb
import os
import time
import urllib.request

def setup_camb_cosmology():
    """
    Set up CAMB parameters for Quijote fiducial cosmology.
    
    Returns
    -------
    camb.CAMBparams
        CAMB parameter object configured for Quijote fiducial cosmology.
        Cosmological parameters: Omega_m=0.3175, Omega_b=0.049, h=0.6711,
        n_s=0.9624, sigma_8=0.834.
    """
    pars = camb.CAMBparams()
    pars.set_cosmology(
        H0=67.11,
        ombh2=0.049 * 0.6711**2,
        omch2=(0.3175 - 0.049) * 0.6711**2,
        mnu=0.0,
        omk=0.0,
        tau=0.0952
    )
    pars.InitPower.set_params(ns=0.9624, As=2.0e-9)
    pars.set_matter_power(redshifts=[0.0, 0.5, 1.0, 2.0, 127.0], kmax=100.0)
    pars.NonLinear = camb.model.NonLinear_none
    return pars


def compute_sigma8_rescaling(pars, target_sigma8=0.834):
    """
    Compute the amplitude rescaling factor to match target sigma_8.
    
    Runs CAMB once to get the current sigma_8, then returns the ratio
    (target_sigma8 / current_sigma8)^2 to rescale the power spectrum amplitude As.
    
    Parameters
    ----------
    pars : camb.CAMBparams
        CAMB parameter object.
    target_sigma8 : float
        Target value of sigma_8 = 0.834 (Quijote fiducial).
    
    Returns
    -------
    float
        Rescaling factor for As such that sigma_8 matches target.
    """
    results = camb.get_results(pars)
    sigma8_current = results.get_sigma8_0()
    rescale = (target_sigma8 / sigma8_current) ** 2
    return rescale, sigma8_current


def get_linear_pk_camb(target_sigma8=0.834, z_list=None, kmax=100.0):
    """
    Compute linear matter power spectrum P(k) using CAMB for Quijote fiducial cosmology.
    
    Rescales As to match sigma_8=0.834 exactly. Returns interpolated P(k) arrays
    at each requested redshift.
    
    Parameters
    ----------
    target_sigma8 : float
        Target sigma_8 value (Quijote fiducial = 0.834).
    z_list : list of float
        Redshifts at which to compute P(k). Default: [0.0, 0.5, 1.0, 2.0, 127.0].
    kmax : float
        Maximum wavenumber in h/Mpc.
    
    Returns
    -------
    k_arr : np.ndarray
        Wavenumber array in h/Mpc.
    pk_dict : dict
        Dictionary mapping redshift (float) to linear P(k) array in (Mpc/h)^3.
    results : camb.CAMBdata
        Full CAMB results object.
    sigma8_final : float
        Final sigma_8 after rescaling.
    growth_factor_z127 : float
        Linear growth factor D(z=127) normalized to D(z=0)=1.
    """
    if z_list is None:
        z_list = [0.0, 0.5, 1.0, 2.0, 127.0]

    pars = setup_camb_cosmology()
    rescale, sigma8_init = compute_sigma8_rescaling(pars, target_sigma8)
    pars.InitPower.As *= rescale

    z_sorted = sorted(z_list, reverse=True)
    pars.set_matter_power(redshifts=z_sorted, kmax=kmax)
    pars.NonLinear = camb.model.NonLinear_none

    results = camb.get_results(pars)
    sigma8_final = results.get_sigma8_0()

    kh, z_out, pk = results.get_matter_power_spectrum(
        minkh=1e-4, maxkh=kmax, npoints=2000
    )

    pk_dict = {}
    for iz, zval in enumerate(z_out):
        zkey = float(round(zval, 4))
        pk_dict[zkey] = pk[iz, :]

    growth_factor_z127 = np.sqrt(pk_dict[127.0][100] / pk_dict[0.0][100])

    return kh, pk_dict, results, sigma8_final, growth_factor_z127


def get_halofit_pk(target_sigma8=0.834, z_list=None, kmax=100.0):
    """
    Compute HaloFit nonlinear matter power spectrum P(k) using CAMB.
    
    Parameters
    ----------
    target_sigma8 : float
        Target sigma_8 value.
    z_list : list of float
        Redshifts at which to compute nonlinear P(k). Default: [0.0, 0.5, 1.0, 2.0].
    kmax : float
        Maximum wavenumber in h/Mpc.
    
    Returns
    -------
    k_nl : np.ndarray
        Wavenumber array in h/Mpc.
    pk_nl_dict : dict
        Dictionary mapping redshift (float) to HaloFit P(k) in (Mpc/h)^3.
    """
    if z_list is None:
        z_list = [0.0, 0.5, 1.0, 2.0]

    pars = setup_camb_cosmology()
    rescale, _ = compute_sigma8_rescaling(pars, target_sigma8)
    pars.InitPower.As *= rescale

    z_sorted = sorted(z_list, reverse=True)
    pars.set_matter_power(redshifts=z_sorted, kmax=kmax)
    pars.NonLinear = camb.model.NonLinear_both

    results = camb.get_results(pars)

    k_nl, z_out, pk_nl = results.get_matter_power_spectrum(
        minkh=1e-4, maxkh=kmax, npoints=2000
    )

    pk_nl_dict = {}
    for iz, zval in enumerate(z_out):
        zkey = float(round(zval, 4))
        pk_nl_dict[zkey] = pk_nl[iz, :]

    return k_nl, pk_nl_dict


def attempt_quijote_download(url, save_path):
    """
    Attempt to download Quijote reference P(k) from GitHub.
    
    Parameters
    ----------
    url : str
        URL to the Quijote P(k) file.
    save_path : str
        Local path to save the downloaded file.
    
    Returns
    -------
    success : bool
        True if download succeeded, False otherwise.
    k_quijote : np.ndarray or None
        Wavenumber array in h/Mpc, or None if download failed.
    pk_quijote : np.ndarray or None
        P(k) array in (Mpc/h)^3, or None if download failed.
    """
    try:
        urllib.request.urlretrieve(url, save_path)
        data = np.loadtxt(save_path)
        k_quijote = data[:, 0]
        pk_quijote = data[:, 1]
        return True, k_quijote, pk_quijote
    except Exception as e:
        print("Quijote download failed: " + str(e))
        return False, None, None


def generate_za_ics(N, L, pk_interp_func, z_init, a_init, H_init, seed=0):
    """
    Generate Zel'dovich Approximation (ZA / 1LPT) initial conditions.
    
    Generates a Gaussian random field in Fourier space with amplitude
    N^3 / sqrt(2*V) * sqrt(P_lin(k, z_init)), then computes the ZA
    displacement field Psi = -i*k/k^2 * delta(k) and displaces particles
    from a regular Lagrangian grid. Velocities are assigned as:
        v_i = a * H(z_init) * f_growth * Psi_i
    with f_growth = 1.0 (matter-dominated approximation at z=127).
    
    Parameters
    ----------
    N : int
        Number of grid cells per side (512 for 512^3 grid).
    L : float
        Box size in Mpc/h.
    pk_interp_func : callable
        Interpolation function for linear P(k) at z_init, taking k in h/Mpc
        and returning P(k) in (Mpc/h)^3.
    z_init : float
        Initial redshift (127.0).
    a_init : float
        Initial scale factor = 1/(1+z_init).
    H_init : float
        Hubble parameter at z_init in km/s/(Mpc/h) = H(z_init)/h * h.
        H(z) = H0 * E(z) where H0=100 h km/s/Mpc, so H_init in units of
        100 km/s/(Mpc/h) * E(z_init).
    seed : int
        Random seed for reproducibility.
    
    Returns
    -------
    pos : np.ndarray, shape (N^3, 3)
        Particle positions in Mpc/h, periodic in [0, L).
    vel : np.ndarray, shape (N^3, 3)
        Particle peculiar velocities in km/s.
    psi_rms : float
        RMS displacement magnitude in Mpc/h.
    """
    rng = np.random.default_rng(seed)

    dx = L / N
    cell_idx = np.arange(N, dtype=np.float32)
    gx, gy, gz = np.meshgrid(cell_idx, cell_idx, cell_idx, indexing='ij')
    q = np.stack([gx.ravel(), gy.ravel(), gz.ravel()], axis=1) * dx

    kf = 2.0 * np.pi / L
    kx = np.fft.fftfreq(N, d=1.0 / N) * kf
    ky = np.fft.fftfreq(N, d=1.0 / N) * kf
    kz = np.fft.rfftfreq(N, d=1.0 / N) * kf

    KX, KY, KZ = np.meshgrid(kx, ky, kz, indexing='ij')
    K2 = KX**2 + KY**2 + KZ**2
    K2[0, 0, 0] = 1.0

    Kmag = np.sqrt(K2)
    Kmag[0, 0, 0] = 1.0

    Pk_grid = np.zeros_like(Kmag)
    mask = Kmag > 0
    Pk_grid[mask] = pk_interp_func(Kmag[mask])
    Pk_grid[Kmag <= 0] = 0.0

    V = L**3
    amplitude = (N**3 / np.sqrt(2.0 * V)) * np.sqrt(Pk_grid)

    n_rfft = N * N * (N // 2 + 1)
    noise_real = rng.standard_normal(n_rfft).reshape(N, N, N // 2 + 1)
    noise_imag = rng.standard_normal(n_rfft).reshape(N, N, N // 2 + 1)
    delta_k = amplitude * (noise_real + 1j * noise_imag)

    delta_k[0, 0, 0] = 0.0

    f_growth = 1.0
    vel_prefactor = a_init * H_init * f_growth

    pos = np.empty((N**3, 3), dtype=np.float32)
    vel = np.empty((N**3, 3), dtype=np.float32)

    for dim in range(3):
        if dim == 0:
            Kdim = KX
        elif dim == 1:
            Kdim = KY
        else:
            Kdim = KZ

        psi_k = -1j * Kdim / K2 * delta_k
        psi_k[0, 0, 0] = 0.0

        psi_real = np.fft.irfftn(psi_k, s=(N, N, N))

        pos[:, dim] = (q[:, dim] + psi_real.ravel()).astype(np.float32)
        vel[:, dim] = (vel_prefactor * psi_real.ravel()).astype(np.float32)

    pos = np.mod(pos, L)

    psi_x = np.fft.irfftn(-1j * KX / K2 * delta_k, s=(N, N, N))
    psi_y = np.fft.irfftn(-1j * KY / K2 * delta_k, s=(N, N, N))
    psi_z = np.fft.irfftn(-1j * KZ / K2 * delta_k, s=(N, N, N))
    psi_rms = float(np.sqrt(np.mean(psi_x**2 + psi_y**2 + psi_z**2)))

    return pos, vel, psi_rms


